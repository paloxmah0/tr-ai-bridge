# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ---- Database (SQLite — no install needed, just a file) ----
DATABASE_URL=sqlite://trading.db?mode=rwc

# ---- LLM (OpenAI-compatible) ----
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECS=60

# ---- Trading mode: paper | signals | live ----
# Mode can be overridden per-account via API.
DEFAULT_TRADING_MODE=paper

# ---- Market data / execution providers ----
# Forex broker adapter (OpenAI-style REST assumed by adapter; override as needed).
FOREX_PROVIDER_BASE_URL=https://api.forexbroker.example/v1
FOREX_PROVIDER_API_KEY=
FOREX_PROVIDER_ACCOUNT_ID=

# OANDA v20 spot broker adapter (forex market data + live spot orders with SL/TP).
# Use https://api-fxpractice.oanda.com (demo) or https://api-fxtrade.oanda.com (live).
OANDA_PROVIDER_BASE_URL=https://api-fxpractice.oanda.com
OANDA_PROVIDER_API_TOKEN=
OANDA_PROVIDER_ACCOUNT_ID=

# Derivative indices broker adapter (Deriv WebSocket API).
DERIV_PROVIDER_BASE_URL=https://api.deriv.com
DERIV_PROVIDER_API_TOKEN=
DERIV_PROVIDER_ACCOUNT_ID=
# Deriv application id (register one at api.deriv.com; 1089 is Deriv's test id).
DERIV_APP_ID=1089
# Candle granularity in seconds (60 = 1min). Used by Deriv adapter + backtests.
DERIV_GRANULARITY_SECS=60

# Engine evaluation cadence (seconds).
ENGINE_TICK_SECS=10

# Upload limits
MAX_NOTE_UPLOAD_BYTES=5242880
